{
	"name": "@aureuma/svelta",
	"private": false,
	"version": "0.1.0",
	"type": "module",
	"files": [
		"packages/blogkit/dist",
		"packages/blogkit/README.md",
		"packages/blogkit/CHANGELOG.md",
		"LICENSE",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./packages/blogkit/dist/index.d.ts",
			"svelte": "./packages/blogkit/dist/index.js",
			"default": "./packages/blogkit/dist/index.js"
		},
		"./server": {
			"types": "./packages/blogkit/dist/server/index.d.ts",
			"default": "./packages/blogkit/dist/server/index.js"
		},
		"./theme": {
			"types": "./packages/blogkit/dist/theme/index.d.ts",
			"svelte": "./packages/blogkit/dist/theme/index.js",
			"default": "./packages/blogkit/dist/theme/index.js"
		}
	},
	"types": "./packages/blogkit/dist/index.d.ts",
	"main": "./packages/blogkit/dist/index.js",
	"svelte": "./packages/blogkit/dist/index.js",
	"peerDependencies": {
		"svelte": "^4.0.0 || ^5.0.0"
	},
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "npm -w @aureuma/blogkit run build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test": "npm run check && npm run test:e2e",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish",
		"prepack": "npm -w @aureuma/blogkit run build"
	},
	"devDependencies": {
		"@changesets/changelog-github": "^0.5.2",
		"@changesets/cli": "^2.29.8",
		"@playwright/test": "^1.58.2",
		"@shikijs/rehype": "^3.22.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/typography": "^0.5.19",
		"@types/node": "^25.2.2",
		"autoprefixer": "^10.4.24",
		"mdsvex": "^0.12.6",
		"postcss": "^8.5.6",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"shiki": "^3.22.0",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"svelte2tsx": "^0.7.47",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"esm-env": "^1.2.2",
		"@fontsource/geist-mono": "^5.2.7",
		"@fontsource/inter": "^5.2.8",
		"gray-matter": "^4.0.3",
		"marked": "^12.0.2",
		"reading-time": "^1.5.0",
		"zod": "^4.3.6"
	},
	"publishConfig": {
		"access": "public"
	}
}
