{
  "name": "@aureuma/svelta-blog",
  "private": false,
  "version": "0.5.0",
  "type": "module",
  "files": [
    "packages/core/dist",
    "packages/core/README.md",
    "packages/core/CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./packages/core/dist/index.d.ts",
      "svelte": "./packages/core/dist/index.js",
      "default": "./packages/core/dist/index.js"
    },
    "./server": {
      "types": "./packages/core/dist/server/index.d.ts",
      "default": "./packages/core/dist/server/index.js"
    },
    "./appearance": {
      "types": "./packages/core/dist/appearance/index.d.ts",
      "svelte": "./packages/core/dist/appearance/index.js",
      "default": "./packages/core/dist/appearance/index.js"
    },
    "./experience": {
      "types": "./packages/core/dist/experience/index.d.ts",
      "default": "./packages/core/dist/experience/index.js"
    }
  },
  "types": "./packages/core/dist/index.d.ts",
  "main": "./packages/core/dist/index.js",
  "svelte": "./packages/core/dist/index.js",
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "node scripts/enforce-pnpm.mjs",
    "dev": "vite dev",
    "build": "vite build",
    "build:core": "pnpm --filter @aureuma/svelta-blog-core build",
    "preview": "vite preview",
    "host:internal": "pnpm build && pnpm preview -- --host 0.0.0.0 --port 4173",
    "prepare": "node scripts/prepare.mjs",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:guard": "node scripts/ensure-ci.mjs",
    "test:server": "pnpm test:guard && pnpm build:core && node --test tests/raw-blog.test.mjs",
    "test:e2e": "pnpm test:guard && playwright test",
    "test": "pnpm test:guard && pnpm check && pnpm test:server && pnpm test:e2e",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepack": "pnpm --filter @aureuma/svelta-blog-core build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.561.0",
    "@playwright/test": "^1.58.2",
    "@shikijs/rehype": "^3.22.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.2.2",
    "autoprefixer": "^10.4.24",
    "bits-ui": "^2.16.2",
    "clsx": "^2.1.1",
    "mdsvex": "^0.12.6",
    "postcss": "^8.5.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte2tsx": "^0.7.47",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "esm-env": "^1.2.2",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2",
    "reading-time": "^1.5.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
