{
  "name": "@aureuma/blogkit",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "svelte": "./dist/theme/index.js",
      "default": "./dist/theme/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "svelte": "./dist/index.js",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/Aureuma/svelta.git",
    "directory": "packages/blogkit"
  },
  "bugs": {
    "url": "https://github.com/Aureuma/svelta/issues"
  },
  "homepage": "https://github.com/Aureuma/svelta/tree/main/packages/blogkit#readme",
  "keywords": [
    "svelte",
    "sveltekit",
    "blog",
    "markdown",
    "mdsvex",
    "shiki",
    "tailwind"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "svelte-package --tsconfig ./tsconfig.json",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "svelte": "^4.0.0 || ^5.0.0"
  },
  "dependencies": {
    "esm-env": "^1.2.2",
    "gray-matter": "^4.0.3",
    "reading-time": "^1.5.0",
    "zod": "^4.3.6"
  }
}
